        "sortBy": [
          {
            "desc": true,
            "displayName": "Temperature"
          }
        ]
      },
      "pluginVersion": "10.2.0",
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb"
          },
          "query": "from(bucket: \"gpu_metrics\")\n  |> range(start: -5m)\n  |> filter(fn: (r) => r._measurement == \"gpu_die_temp_celsius\" and r._field == \"value\")\n  |> group(columns: [\"target_name\", \"sensor_path\"])\n  |> max()\n  |> filter(fn: (r) => r._value > 80.0)\n  |> group()\n  |> rename(columns: {_value: \"Temperature\"})\n  |> keep(columns: [\"target_name\", \"sensor_path\", \"Temperature\"])",
          "refId": "A"
        }
      ],
      "title": "Hot GPUs (>80°C)",
      "type": "table"
    },
