          "query": "import \"experimental\"\n\nfrom(bucket: \"gpu_metrics\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"gpu_die_temp_celsius\" and r._field == \"value\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> group(columns: [\"_time\"])\n  |> experimental.quantile(q: 0.50, method: \"exact_mean\")\n  |> group()\n  |> yield(name: \"p50\")",
