          "query": "from(bucket: \"gpu_metrics\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"gpu_die_temp_celsius\" and r._field == \"value\")\n  |> filter(fn: (r) => r.target_name =~ /${target_filter}/)\n  |> aggregateWindow(every: ${aggregation}, fn: mean, createEmpty: false)\n  |> limit(n: ${max_systems}, offset: 0)\n  |> pivot(rowKey:[\"_time\"], columnKey: [\"target_name\", \"sensor_path\"], valueColumn: \"_value\")",
          "refId": "A"
        }
      ],
      "title": "GPU Temperature Heatmap (Showing up to ${max_systems} systems matching: ${target_filter})",
