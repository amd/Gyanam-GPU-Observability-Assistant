# Shellcheck configuration
# Disable specific warnings

# SC2086: Double quote to prevent globbing and word splitting
# Sometimes intentional for array expansion
disable=SC2086

# SC2164: Use cd ... || exit in case cd fails
# Not needed in controlled scripts with set -e
disable=SC2164

# SC1091: Not following sourced files
# .env files are dynamic and don't exist during linting
disable=SC1091

# SC2181: Check exit code directly with if mycmd
# Sometimes checking $? is more readable
disable=SC2181
